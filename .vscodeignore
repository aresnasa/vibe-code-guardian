# ── Source & config (bundled by esbuild) ──────────────────────
.vscode/**
.vscode-test/**
out/**
node_modules/**
src/**
.gitignore
.gitmodules
.yarnrc
esbuild.js
**/tsconfig.json
**/eslint.config.mjs
**/*.map
**/*.ts
**/.vscode-test.*

# ── Documentation (only README + CHANGELOG ship) ─────────────
docs/**
CHANGELOG.md

# ── Scripts (dev-only) ────────────────────────────────────────
scripts/**

# ── Zed extension build artifacts ────────────────────────────
zed/target/**

# ── Internal / private files ─────────────────────────────────
.claude/**
.github/**
.backup/**
Claude.md

# ── Test artifacts ────────────────────────────────────────────
test-*.txt

# ── Packaged extensions (don't nest .vsix inside .vsix) ──────
*.vsix
